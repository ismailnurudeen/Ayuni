# Server Configuration
PORT=3000

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/ayuni_dev
DATABASE_SSL=false

# Twilio SMS Configuration (fallback OTP provider)
# Get credentials from https://console.twilio.com/
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+234xxxxxxxxxx

# Firebase Phone Auth Configuration (MVP default)
# Download service account JSON from Firebase Console → Project Settings → Service Accounts
# Paste the entire JSON as a single line, or set GOOGLE_APPLICATION_CREDENTIALS to the file path
FIREBASE_SERVICE_ACCOUNT_JSON=
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Auth Provider: "firebase" (MVP default) or "twilio"
AUTH_PROVIDER=firebase

# Paystack Payment Configuration
# Get secret key from https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=sk_test_your_secret_key_here

# Environment
NODE_ENV=development
